<UserControl x:Class="MidiControllerFrontend.Views.MidiSendEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MidiControllerFrontend.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Gerät:"     VerticalAlignment="Center" Margin="0,0,0,4"/>
        <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                   ItemsSource="{Binding ActiveDevices, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   DisplayMemberPath="DeviceId"
                   SelectedValuePath="DeviceId"
                   SelectedValue="{Binding DeviceId}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Typ:"       VerticalAlignment="Center" Margin="0,0,0,4"/>
        <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                   ItemsSource="{x:Static local:ValueSourceNamesProxy.MidiEventTypes}"
                   SelectedItem="{Binding EventType}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Kanal:"     VerticalAlignment="Center" Margin="0,0,0,4"/>
        <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"
                   Text="{Binding Channel, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Data1:"     VerticalAlignment="Center" Margin="0,0,0,4"/>
        <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,0,0,4"
                   Text="{Binding Data1, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Data2:"     VerticalAlignment="Center"/>
        <TextBox   Grid.Row="4" Grid.Column="1"
                   Text="{Binding Data2, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
</UserControl>

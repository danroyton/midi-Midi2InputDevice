<UserControl x:Class="MidiControllerFrontend.Views.MappingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MidiControllerFrontend.Views"
             mc:Ignorable="d" d:DesignHeight="600" d:DesignWidth="900">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Trigger-Liste -->
            <ColumnDefinition Width="*"/>
            <!-- Editor-Panel -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ── Linke Spalte: Trigger-Liste ────────────────────────── -->
        <DockPanel Grid.Column="0" Margin="12">

            <!-- Titel + Aktionsleiste -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Mappings" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Content="+ Neu"
                        Command="{Binding NewTriggerCommand}"
                        HorizontalAlignment="Right"
                        Padding="10,3"/>
            </DockPanel>

            <!-- Gerätefilter -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Gerät:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox ItemsSource="{Binding ActiveDevices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="DeviceId"
                          MinWidth="200" VerticalAlignment="Center"/>
                <Button Content="&#x21BB;"
                        Command="{Binding LoadActiveDevicesCommand}"
                        ToolTip="Geräteliste aktualisieren"
                        Margin="6,0,0,0" Padding="6,2"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Statuszeile -->
            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding StatusMessage}"
                       Foreground="Gray" FontStyle="Italic" Margin="0,6,0,0"/>

            <!-- Trigger-Liste -->
            <ListView ItemsSource="{Binding Triggers}"
                      SelectedItem="{Binding SelectedTrigger}"
                      BorderThickness="1" BorderBrush="#CCCCCC">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name"      Width="160"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Tasten"    Width="160"
                                        DisplayMemberBinding="{Binding KeysSummary}"/>
                        <GridViewColumn Header="Gerät"     Width="140"
                                        DisplayMemberBinding="{Binding DeviceId}"/>
                        <GridViewColumn Header="Typ"       Width="110"
                                        DisplayMemberBinding="{Binding EventType}"/>
                        <GridViewColumn Header="Ch"        Width="40"
                                        DisplayMemberBinding="{Binding Channel}"/>
                        <GridViewColumn Header="Data1"     Width="50"
                                        DisplayMemberBinding="{Binding Data1Filter}"/>
                        <GridViewColumn Header="" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✎"
                                                Command="{Binding DataContext.EditTriggerCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Bearbeiten"
                                                Padding="5,1" Margin="0,0,4,0"/>
                                        <Button Content="🗑"
                                                Command="{Binding DataContext.DeleteTriggerCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Löschen"
                                                Padding="5,1"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </DockPanel>

        <!-- ── Rechte Spalte: Trigger-Editor ──────────────────────── -->
        <Border Grid.Column="1"
                Visibility="{Binding IsEditorOpen, Converter={StaticResource BoolToVisibility}}"
                Width="380"
                BorderThickness="1,0,0,0" BorderBrush="#AAAAAA"
                Background="#F8F8F8">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,12">

                    <TextBlock Text="Trigger bearbeiten"
                               FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- Anzeigename -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Name:" VerticalAlignment="Center" Width="80"/>
                        <TextBox Text="{Binding Editor.Name, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="240" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ── Pre-Zuweisungen ──────────────────────────────── -->
                    <GroupBox Header="Pre: Variablen &amp; MIDI-Send (vor Prüfung)" Margin="0,0,0,10" Padding="8">
                        <StackPanel>
                            <!-- Variablen-Zuweisungen -->
                            <TextBlock Text="Variablen setzen:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding Editor.PreAssignments}"
                                     SelectedItem="{Binding Editor.SelectedPreAssignment}"
                                     MaxHeight="80" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ Variable" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.AddPreAssignmentCommand}"/>
                                <Button Content="🗑"  Padding="6,2"
                                        Command="{Binding Editor.RemovePreAssignmentCommand}"
                                        CommandParameter="{Binding Editor.SelectedPreAssignment}"
                                        IsEnabled="{Binding Editor.SelectedPreAssignment, Converter={StaticResource NotNull}}"/>
                            </StackPanel>
                            <!-- Inline-Editor der gewählten Pre-Zuweisung -->
                            <Border Visibility="{Binding Editor.SelectedPreAssignment, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="8" Margin="0,0,0,8">
                                <Grid DataContext="{Binding Editor.SelectedPreAssignment}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Variable:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                               ItemsSource="{x:Static local:ValueSourceNamesProxy.Variables}"
                                               SelectedItem="{Binding Variable}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Quelle:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                                               ItemsSource="{x:Static local:ValueSourceNamesProxy.WritableSources}"
                                               SelectedItem="{Binding Source}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Wert:"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding FixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1"
                                               Text="{Binding FixedValue, UpdateSourceTrigger=PropertyChanged}"
                                               Visibility="{Binding FixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>

                            <!-- MIDI-Send -->
                            <TextBlock Text="MIDI senden:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding Editor.PreMidiSend}"
                                     SelectedItem="{Binding Editor.SelectedPreMidiSend}"
                                     MaxHeight="80" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ MIDI" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.AddPreMidiSendCommand}"/>
                                <Button Content="🗑"  Padding="6,2"
                                        Command="{Binding Editor.RemovePreMidiSendCommand}"
                                        CommandParameter="{Binding Editor.SelectedPreMidiSend}"
                                        IsEnabled="{Binding Editor.SelectedPreMidiSend, Converter={StaticResource NotNull}}"/>
                            </StackPanel>
                            <Border Visibility="{Binding Editor.SelectedPreMidiSend, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="8">
                                <local:MidiSendEditor DataContext="{Binding Editor.SelectedPreMidiSend}"
                                                      ActiveDevices="{Binding DataContext.ActiveDevices,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- Mitschnitt -->
                    <GroupBox Header="MIDI-Mitschnitt" Margin="0,0,0,10" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▶ Mitschneiden"
                                        Command="{Binding StartCaptureCommand}"
                                        IsEnabled="{Binding IsCapturing, Converter={StaticResource BoolNegate}}"
                                        Padding="8,3" Margin="0,0,6,0"/>
                                <Button Content="■ Stop"
                                        Command="{Binding StopCaptureCommand}"
                                        IsEnabled="{Binding IsCapturing}"
                                        Padding="8,3"/>
                            </StackPanel>
                            <TextBlock Text="{Binding CaptureStatus}"
                                       Foreground="SteelBlue" FontStyle="Italic"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Matching-Parameter -->
                    <GroupBox Header="Filter" Margin="0,0,0,10" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gerät:"
                                       VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1"
                                       ItemsSource="{Binding ActiveDevices}"
                                       SelectedValuePath="DeviceId"
                                       SelectedValue="{Binding Editor.DeviceId}"
                                       DisplayMemberPath="DeviceId"
                                       Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Event-Typ:"
                                       VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1"
                                       ItemsSource="{Binding EventTypes}"
                                       SelectedItem="{Binding Editor.EventType}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Kanal:"
                                       VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBox   Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Editor.Channel, UpdateSourceTrigger=PropertyChanged}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Data1:"
                                       VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBox   Grid.Row="3" Grid.Column="1"
                                       Text="{Binding Editor.Data1Filter, UpdateSourceTrigger=PropertyChanged}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Match:"
                                       VerticalAlignment="Center" Margin="0,0,0,6"/>
                            <ComboBox  Grid.Row="4" Grid.Column="1"
                                       ItemsSource="{Binding MatchModes}"
                                       SelectedItem="{Binding Editor.MatchMode}"
                                       Margin="0,0,0,6"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Wert:"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding Editor.MatchValueVisible,
                                                    Converter={StaticResource BoolToVisibility}}"/>
                            <TextBox   Grid.Row="5" Grid.Column="1"
                                       Text="{Binding Editor.MatchValue, UpdateSourceTrigger=PropertyChanged}"
                                       Visibility="{Binding Editor.MatchValueVisible,
                                                    Converter={StaticResource BoolToVisibility}}"/>
                        </Grid>
                    </GroupBox>

                    <!-- Aktionen -->
                    <GroupBox Header="Aktionen" Margin="0,0,0,10" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Liste der Aktionen -->
                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding Editor.Actions}"
                                     SelectedItem="{Binding Editor.SelectedAction}"
                                     MaxHeight="120"
                                     Margin="0,0,0,6">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Aktions-Buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="+ Aktion"
                                        Command="{Binding Editor.AddActionCommand}"
                                        Padding="8,3" Margin="0,0,6,0"/>
                                <Button Content="🗑 Entfernen"
                                        Command="{Binding Editor.RemoveActionCommand}"
                                        CommandParameter="{Binding Editor.SelectedAction}"
                                        IsEnabled="{Binding Editor.SelectedAction, Converter={StaticResource NotNull}}"
                                        Padding="8,3"/>
                            </StackPanel>

                            <!-- Inline-Editor der gewählten Aktion -->
                            <Border Grid.Row="2"
                                    Visibility="{Binding Editor.SelectedAction, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC"
                                    Background="#FAFAFA" Padding="8">
                                <Grid DataContext="{Binding Editor.SelectedAction}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tasten:"
                                               VerticalAlignment="Top" Margin="0,4,0,6"
                                               ToolTip="Modifier + Haupttaste wählen"/>
                                    <local:KeyComboEditor
                                               Grid.Row="0" Grid.Column="1"
                                               KeysValue="{Binding Keys, UpdateSourceTrigger=PropertyChanged}"
                                               Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Wiederh.:"
                                               VerticalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBox   Grid.Row="1" Grid.Column="1"
                                               Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                                               Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Dauer (ms):"
                                               VerticalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1"
                                               Text="{Binding DurationMs, UpdateSourceTrigger=PropertyChanged}"
                                               Margin="0,0,0,6"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Pause (ms):"
                                               VerticalAlignment="Center"/>
                                    <TextBox   Grid.Row="3" Grid.Column="1"
                                               Text="{Binding PauseMs, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </GroupBox>

                    <!-- ── Post-Zuweisungen ─────────────────────────────── -->
                    <GroupBox Header="Post: Variablen &amp; MIDI-Send (nach Aktionen)" Margin="0,0,0,10" Padding="8">
                        <StackPanel>
                            <!-- Variablen-Zuweisungen -->
                            <TextBlock Text="Variablen setzen:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding Editor.PostAssignments}"
                                     SelectedItem="{Binding Editor.SelectedPostAssignment}"
                                     MaxHeight="80" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ Variable" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.AddPostAssignmentCommand}"/>
                                <Button Content="🗑" Padding="6,2"
                                        Command="{Binding Editor.RemovePostAssignmentCommand}"
                                        CommandParameter="{Binding Editor.SelectedPostAssignment}"
                                        IsEnabled="{Binding Editor.SelectedPostAssignment, Converter={StaticResource NotNull}}"/>
                            </StackPanel>
                            <Border Visibility="{Binding Editor.SelectedPostAssignment, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="8" Margin="0,0,0,8">
                                <Grid DataContext="{Binding Editor.SelectedPostAssignment}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Variable:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                               ItemsSource="{x:Static local:ValueSourceNamesProxy.Variables}"
                                               SelectedItem="{Binding Variable}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Quelle:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                                               ItemsSource="{x:Static local:ValueSourceNamesProxy.WritableSources}"
                                               SelectedItem="{Binding Source}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Wert:"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding FixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1"
                                               Text="{Binding FixedValue, UpdateSourceTrigger=PropertyChanged}"
                                               Visibility="{Binding FixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>

                            <!-- MIDI-Send -->
                            <TextBlock Text="MIDI senden:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding Editor.PostMidiSend}"
                                     SelectedItem="{Binding Editor.SelectedPostMidiSend}"
                                     MaxHeight="80" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ MIDI" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.AddPostMidiSendCommand}"/>
                                <Button Content="🗑" Padding="6,2"
                                        Command="{Binding Editor.RemovePostMidiSendCommand}"
                                        CommandParameter="{Binding Editor.SelectedPostMidiSend}"
                                        IsEnabled="{Binding Editor.SelectedPostMidiSend, Converter={StaticResource NotNull}}"/>
                            </StackPanel>
                            <Border Visibility="{Binding Editor.SelectedPostMidiSend, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="8">
                                <local:MidiSendEditor DataContext="{Binding Editor.SelectedPostMidiSend}"
                                                      ActiveDevices="{Binding DataContext.ActiveDevices,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- ── Bedingungen (IF) ─────────────────────────────── -->
                    <GroupBox Header="Bedingungen (IF – leer = immer ausführen)" Margin="0,0,0,10" Padding="8">
                        <StackPanel>
                            <ListBox ItemsSource="{Binding Editor.ConditionBlocks}"
                                     SelectedItem="{Binding Editor.SelectedConditionBlock}"
                                     MaxHeight="80" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Summary}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ Block" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.AddConditionBlockCommand}"/>
                                <Button Content="🗑" Padding="6,2"
                                        Command="{Binding Editor.RemoveConditionBlockCommand}"
                                        CommandParameter="{Binding Editor.SelectedConditionBlock}"
                                        IsEnabled="{Binding Editor.SelectedConditionBlock, Converter={StaticResource NotNull}}"/>
                            </StackPanel>

                            <!-- Inline-Editor des gewählten Condition-Blocks -->
                            <Border Visibility="{Binding Editor.SelectedConditionBlock, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="8">
                                <StackPanel DataContext="{Binding Editor.SelectedConditionBlock}">
                                    <!-- Template-Option -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <CheckBox Content="Template verwenden" IsChecked="{Binding UseTemplate}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding UseTemplate, Converter={StaticResource BoolToVisibility}}"
                                                Margin="0,0,0,6">
                                        <TextBlock Text="Template:" VerticalAlignment="Center" Width="70"/>
                                        <TextBox Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}" MinWidth="160"/>
                                    </StackPanel>

                                    <!-- Inline-Bedingungen (OR-verknüpft) -->
                                    <StackPanel Visibility="{Binding UseTemplate, Converter={StaticResource InverseBoolToVisibility}}">
                                        <TextBlock Text="Bedingungen (ODER-verknüpft):" FontStyle="Italic" Margin="0,0,0,4"/>
                                        <ListBox ItemsSource="{Binding Conditions}"
                                                 SelectedItem="{Binding SelectedCondition}"
                                                 MaxHeight="80" Margin="0,0,0,4">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Summary}"/>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Button Content="+ Bed." Padding="6,2" Margin="0,0,6,0"
                                                    Command="{Binding AddConditionCommand}"/>
                                            <Button Content="🗑" Padding="6,2"
                                                    Command="{Binding RemoveConditionCommand}"
                                                    CommandParameter="{Binding SelectedCondition}"
                                                    IsEnabled="{Binding SelectedCondition, Converter={StaticResource NotNull}}"/>
                                        </StackPanel>
                                        <!-- Inline-Editor der gewählten Condition -->
                                        <Border Visibility="{Binding SelectedCondition, Converter={StaticResource NotNullToVisibility}}"
                                                BorderThickness="1" BorderBrush="#DDDDDD" Background="White" Padding="6">
                                            <Grid DataContext="{Binding SelectedCondition}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="65"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Links:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                                           ItemsSource="{x:Static local:ValueSourceNamesProxy.ConditionSources}"
                                                           SelectedItem="{Binding Left}"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Op:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                                                           ItemsSource="{x:Static local:ValueSourceNamesProxy.CompareOps}"
                                                           SelectedItem="{Binding Op}"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Rechts:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                <ComboBox  Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"
                                                           ItemsSource="{x:Static local:ValueSourceNamesProxy.ConditionSources}"
                                                           SelectedItem="{Binding RightSource}"/>
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Wert:"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding RightFixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                                <TextBox   Grid.Row="3" Grid.Column="1"
                                                           Text="{Binding RightFixed, UpdateSourceTrigger=PropertyChanged}"
                                                           Visibility="{Binding RightFixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- ── ELSE-Zweig ───────────────────────────────────── -->
                    <GroupBox Margin="0,0,0,10" Padding="8">
                        <GroupBox.Header>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding Editor.HasElse}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="ELSE-Zweig aktivieren" VerticalAlignment="Center"/>
                            </StackPanel>
                        </GroupBox.Header>
                        <StackPanel Visibility="{Binding Editor.HasElse, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="ELSE-Aktionen:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding Editor.Else.Actions}"
                                     SelectedItem="{Binding Editor.Else.SelectedAction}"
                                     MaxHeight="80" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Summary}"/></DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="+ Aktion" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.Else.AddActionCommand}"/>
                                <Button Content="🗑" Padding="6,2"
                                        Command="{Binding Editor.Else.RemoveActionCommand}"
                                        CommandParameter="{Binding Editor.Else.SelectedAction}"
                                        IsEnabled="{Binding Editor.Else.SelectedAction, Converter={StaticResource NotNull}}"/>
                            </StackPanel>

                            <TextBlock Text="ELSE Post-Variablen:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding Editor.Else.PostAssignments}"
                                     SelectedItem="{Binding Editor.Else.SelectedPostAssignment}"
                                     MaxHeight="60" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Summary}"/></DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="+ Variable" Padding="6,2" Margin="0,0,6,0"
                                        Command="{Binding Editor.Else.AddPostAssignmentCommand}"/>
                                <Button Content="🗑" Padding="6,2"
                                        Command="{Binding Editor.Else.RemovePostAssignmentCommand}"
                                        CommandParameter="{Binding Editor.Else.SelectedPostAssignment}"
                                        IsEnabled="{Binding Editor.Else.SelectedPostAssignment, Converter={StaticResource NotNull}}"/>
                            </StackPanel>
                            <Border Visibility="{Binding Editor.Else.SelectedPostAssignment, Converter={StaticResource NotNullToVisibility}}"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Background="#FAFAFA" Padding="8" Margin="0,0,0,8">
                                <Grid DataContext="{Binding Editor.Else.SelectedPostAssignment}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Variable:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                               ItemsSource="{x:Static local:ValueSourceNamesProxy.Variables}"
                                               SelectedItem="{Binding Variable}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Quelle:" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                    <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                                               ItemsSource="{x:Static local:ValueSourceNamesProxy.WritableSources}"
                                               SelectedItem="{Binding Source}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Wert:"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding FixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBox   Grid.Row="2" Grid.Column="1"
                                               Text="{Binding FixedValue, UpdateSourceTrigger=PropertyChanged}"
                                               Visibility="{Binding FixedVisible, Converter={StaticResource BoolToVisibility}}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <!-- Footer-Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Abbrechen"
                                Command="{Binding CancelEditCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="Speichern"
                                Command="{Binding SaveTriggerCommand}"
                                Padding="10,4"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

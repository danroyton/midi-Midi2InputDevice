<Application x:Class="MidiControllerFrontend.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MidiControllerFrontend"
             xmlns:conv="clr-namespace:MidiControllerFrontend.Converters">
    <Application.Resources>
        <conv:BoolToVisibilityConverter     x:Key="BoolToVisibility"/>
        <conv:BoolNegateConverter           x:Key="BoolNegate"/>
        <conv:NotNullConverter              x:Key="NotNull"/>
        <conv:NotNullToVisibilityConverter  x:Key="NotNullToVisibility"/>
    </Application.Resources>
</Application>

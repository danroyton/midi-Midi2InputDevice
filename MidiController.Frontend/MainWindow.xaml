<Window x:Class="MidiControllerFrontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:MidiControllerFrontend.Views"
        mc:Ignorable="d"
        Title="MidiController" Height="640" Width="1024"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Nav-Button-Stil -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Top-Bar ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#212121" Padding="12,6">
            <DockPanel>
                <TextBlock Text="MidiController" Foreground="White"
                           FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>

                <!-- Status-Indikator -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Margin="0,0,6,0"
                             Fill="{Binding IndicatorBrush}"/>
                    <ComboBox ItemsSource="{Binding Profiles}"
                              SelectedItem="{Binding SelectedProfile}"
                              MinWidth="140" Margin="0,0,6,0"/>
                    <Button Content="+ Neu"
                            Command="{Binding NewProfileCommand}"
                            Padding="8,2" Margin="0,0,4,0"
                            Background="#2196F3" Foreground="White" BorderThickness="0"/>
                    <Button Content="🗑"
                            Command="{Binding DeleteProfileCommand}"
                            ToolTip="Profil löschen"
                            Padding="8,2" Margin="0,0,4,0"
                            Background="#F44336" Foreground="White" BorderThickness="0"/>
                    <Button Content="Aktivieren"
                            Command="{Binding ActivateProfileCommand}"
                            Padding="8,2" Background="#4CAF50" Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Nav-Leiste ────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Left" Width="130" Background="#2D2D2D">
            <StackPanel Margin="0,8">
                <Button Content="Devices"   Tag="Devices"   Style="{StaticResource NavButtonStyle}"
                        Foreground="White" Command="{Binding NavigateCommand}" CommandParameter="Devices"/>
                <Button Content="Mappings"  Tag="Mappings"  Style="{StaticResource NavButtonStyle}"
                        Foreground="White" Command="{Binding NavigateCommand}" CommandParameter="Mappings"/>
                <Button Content="Templates" Tag="Templates" Style="{StaticResource NavButtonStyle}"
                        Foreground="White" Command="{Binding NavigateCommand}" CommandParameter="Templates"/>
                <Button Content="Log"       Tag="Log"       Style="{StaticResource NavButtonStyle}"
                        Foreground="White" Command="{Binding NavigateCommand}" CommandParameter="Log"/>
                <Button Content="KeyTest"   Tag="KeyTest"   Style="{StaticResource NavButtonStyle}"
                        Foreground="White" Command="{Binding NavigateCommand}" CommandParameter="KeyTest"/>
                <Button Content="Status"    Tag="Status"    Style="{StaticResource NavButtonStyle}"
                        Foreground="White" Command="{Binding NavigateCommand}" CommandParameter="Status"/>
            </StackPanel>
        </Border>

        <!-- ── Content-Area ──────────────────────────────────────────────── -->
        <Border Background="White">
            <ContentControl x:Name="ContentArea"/>
        </Border>

    </DockPanel>
</Window>
